# Firebase
FIREBASE_PROJECT_ID=cutway-pi
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@cutway-pi.iam.gserviceaccount.com

# Pi Network
PI_API_KEY=your_pi_api_key_here
PI_SANDBOX=true

# App
PORT=3000
APP_URL=https://cutway.pi
OWNER_PI_WALLET=your_pi_wallet_address_here
PLATFORM_FEE_PI=1

# Security
JWT_SECRET=your_super_secret_jwt_key_here
